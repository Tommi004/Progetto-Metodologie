<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="it.unicam.cs.mpgc.rpg126224.view.CharacterCreationViewController">

    <!-- Particle canvas background -->
    <Pane fx:id="particlePane"
          style="-fx-background-color: #0d0d20;"
          maxWidth="Infinity" maxHeight="Infinity"/>

    <!-- Main layout: form left, preview right -->
    <HBox alignment="CENTER" spacing="40"
          style="-fx-padding: 40;">

        <!-- Left: form -->
        <VBox alignment="CENTER" spacing="18" minWidth="380">

            <Label fx:id="titleLabel" text="DUNGEON PROTOCOL"
                   style="-fx-font-family: Monospace; -fx-font-size: 30;
                          -fx-font-weight: bold; -fx-text-fill: #e94560;"/>

            <Label text="Create Your Hero"
                   style="-fx-font-family: Monospace; -fx-font-size: 15;
                          -fx-text-fill: #6060a0;"/>

            <Separator style="-fx-background-color: #2a2a4a;" maxWidth="320"/>

            <!-- Name -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="Hero Name:"
                       style="-fx-font-family: Monospace; -fx-font-size: 13;
                              -fx-font-weight: bold; -fx-text-fill: #c0c0ff;"/>
                <TextField fx:id="nameField"
                           maxWidth="300"
                           promptText="Enter your name..."
                           style="-fx-background-color: #10102a; -fx-text-fill: #e0e0ff;
                                  -fx-border-color: #e94560; -fx-border-radius: 5;
                                  -fx-background-radius: 5; -fx-font-family: Monospace;
                                  -fx-font-size: 13; -fx-padding: 7 12;"/>
            </VBox>

            <!-- Class selection -->
            <VBox spacing="10" alignment="CENTER">
                <Label text="Choose Class:"
                       style="-fx-font-family: Monospace; -fx-font-size: 13;
                              -fx-font-weight: bold; -fx-text-fill: #c0c0ff;"/>
                <HBox fx:id="classBox" alignment="CENTER" spacing="12"/>
            </VBox>

            <!-- Class description -->
            <Label fx:id="classInfo"
                   maxWidth="360" wrapText="true" alignment="CENTER"
                   style="-fx-font-family: Monospace; -fx-font-size: 11;
                          -fx-text-fill: #6090c0; -fx-padding: 0 10;"/>

            <Separator style="-fx-background-color: #2a2a4a;" maxWidth="320"/>

            <!-- Start button -->
            <Button fx:id="startBtn"
                    text="⚔   ENTER THE DUNGEON"
                    onAction="#handleStart"
                    style="-fx-background-color: #8b1a2a; -fx-text-fill: white;
                           -fx-font-family: Monospace; -fx-font-size: 14;
                           -fx-padding: 11 28; -fx-background-radius: 6; -fx-cursor: hand;"/>

        </VBox>

        <!-- Right: animated class preview -->
        <VBox fx:id="previewPanel" alignment="CENTER" spacing="14"
              minWidth="220"
              style="-fx-background-color: #0a0a1e; -fx-border-color: #1e1e4a;
                     -fx-border-radius: 12; -fx-background-radius: 12;
                     -fx-padding: 28;">

            <Label fx:id="previewAvatar"
                   alignment="CENTER" maxWidth="Infinity"
                   style="-fx-font-size: 64;"/>

            <Label fx:id="previewClassName"
                   alignment="CENTER" maxWidth="Infinity"
                   style="-fx-font-family: Monospace; -fx-font-size: 16;
                          -fx-font-weight: bold; -fx-text-fill: #e0e0ff;"/>

            <!-- Stat bars -->
            <VBox fx:id="statBars" spacing="8" minWidth="180"/>

        </VBox>

    </HBox>

</StackPane>
