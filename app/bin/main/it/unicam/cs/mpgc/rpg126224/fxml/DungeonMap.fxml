<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg126224.view.DungeonMapViewController">

    <top>
        <HBox fx:id="headerBox" alignment="CENTER" spacing="10"
              style="-fx-padding: 6 12 6 12;">
            <Label fx:id="levelIconLabel" style="-fx-font-size: 20;"/>
            <Label fx:id="dungeonNameLabel"
                   style="-fx-font-family: Monospace; -fx-font-size: 13;
                          -fx-font-weight: bold;"/>
            <Label fx:id="levelLabel"
                   style="-fx-font-family: Monospace; -fx-font-size: 11;
                          -fx-text-fill: #808080;"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <!-- Dark overlay behind canvas -->
            <Pane fx:id="darkOverlay"
                  style="-fx-background-color: rgba(0,0,0,0.3);"
                  prefWidth="470" prefHeight="480"/>
            <!-- Canvas placeholder — particle canvas inserted here programmatically -->
            <StackPane fx:id="canvasPlaceholder"
                       style="-fx-background-color: transparent;"
                       StackPane.alignment="TOP_LEFT"/>
        </StackPane>
    </center>

</BorderPane>
