<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #0a0010; -fx-padding: 15;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg126224.view.CombatViewController">

    <top>
        <HBox alignment="CENTER" spacing="20"
              style="-fx-padding: 0 0 12 0;">

            <!-- Hero panel — StackPane so damage numbers float above -->
            <StackPane fx:id="heroPanelBox">
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: #0d0d2a; -fx-border-color: #1a2a5a;
                             -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                    <Label fx:id="heroAvatar" alignment="CENTER"
                           style="-fx-font-size: 52;"/>
                    <Label fx:id="heroNameLabel"
                           style="-fx-font-family: Monospace; -fx-font-size: 13;
                                  -fx-font-weight: bold; -fx-text-fill: #00e5ff;"/>
                    <Label fx:id="heroHpLabel"
                           style="-fx-font-family: Monospace; -fx-font-size: 11;
                                  -fx-text-fill: #a0d0ff;"/>
                    <ProgressBar fx:id="heroHpBar" prefWidth="160"
                                 style="-fx-accent: #00e5ff; -fx-background-color: #1a1a3a;"/>
                    <Label fx:id="heroLevelLabel"
                           style="-fx-font-family: Monospace; -fx-font-size: 10;
                                  -fx-text-fill: #6080a0;"/>
                </VBox>
            </StackPane>

            <!-- VS -->
            <Label fx:id="vsLabel" text="VS"
                   style="-fx-font-family: Monospace; -fx-font-size: 24;
                          -fx-font-weight: bold; -fx-text-fill: #e94560;"/>

            <!-- Enemy panel — StackPane so damage numbers float above -->
            <StackPane fx:id="enemyPanelBox">
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: #1a0a0a; -fx-border-color: #5a1a1a;
                             -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                    <Label fx:id="enemyAvatar" alignment="CENTER"
                           style="-fx-font-size: 52;"/>
                    <Label fx:id="enemyNameLabel"
                           style="-fx-font-family: Monospace; -fx-font-size: 13;
                                  -fx-font-weight: bold; -fx-text-fill: #ff4466;"/>
                    <Label fx:id="enemyHpLabel"
                           style="-fx-font-family: Monospace; -fx-font-size: 11;
                                  -fx-text-fill: #ffa0a0;"/>
                    <ProgressBar fx:id="enemyHpBar" prefWidth="160"
                                 style="-fx-accent: #ff4444; -fx-background-color: #2a0a0a;"/>
                    <Label fx:id="enemyTypeLabel"
                           style="-fx-font-family: Monospace; -fx-font-size: 10;
                                  -fx-text-fill: #804040;"/>
                </VBox>
            </StackPane>

        </HBox>
    </top>

    <center>
        <TextArea fx:id="logArea"
                  editable="false" wrapText="true" prefHeight="160"
                  style="-fx-control-inner-background: #050010; -fx-text-fill: #c8b8ff;
                         -fx-font-family: Monospace; -fx-font-size: 12;
                         -fx-border-color: #2a1a4a; -fx-border-radius: 4;
                         -fx-padding: 8 0 8 0;"/>
    </center>

    <bottom>
        <HBox fx:id="actionBar" alignment="CENTER" spacing="10"
              style="-fx-padding: 6 0 0 0;">
            <Button fx:id="attackBtn"  text="⚔  Attack"  prefWidth="120" onAction="#handleAttack"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white;
                           -fx-font-family: Monospace; -fx-font-size: 12;
                           -fx-padding: 10 8; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Button fx:id="specialBtn" text="✦  Special" prefWidth="120" onAction="#handleSpecial"
                    style="-fx-background-color: #6c3483; -fx-text-fill: white;
                           -fx-font-family: Monospace; -fx-font-size: 12;
                           -fx-padding: 10 8; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Button fx:id="potionBtn"  text="🧪  Potion"  prefWidth="120" onAction="#handlePotion"
                    style="-fx-background-color: #1a5c2a; -fx-text-fill: white;
                           -fx-font-family: Monospace; -fx-font-size: 12;
                           -fx-padding: 10 8; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Button fx:id="fleeBtn"    text="🏃  Flee"    prefWidth="120" onAction="#handleFlee"
                    style="-fx-background-color: #444455; -fx-text-fill: white;
                           -fx-font-family: Monospace; -fx-font-size: 12;
                           -fx-padding: 10 8; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>
