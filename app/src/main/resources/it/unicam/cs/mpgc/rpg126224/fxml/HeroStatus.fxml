<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="5"
      minWidth="190" maxWidth="190"
      style="-fx-background-color: #0a0a1e; -fx-border-color: #1e1e4a;
             -fx-border-width: 0 1 0 0; -fx-padding: 12;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg126224.view.HeroStatusViewController">

    <!-- Titolo -->
    <Label text="-- HERO --" maxWidth="Infinity" alignment="CENTER"
           style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-font-weight: bold;
                  -fx-text-fill: #e94560;"/>

    <!-- Avatar -->
    <Label fx:id="avatarLabel" maxWidth="Infinity" alignment="CENTER"
           style="-fx-font-size: 40;"/>

    <!-- Nome e classe -->
    <Label fx:id="nameLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-font-weight: bold;
                  -fx-text-fill: #00e5ff;"/>
    <Label fx:id="classLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 11;
                  -fx-text-fill: #8080c0;"/>
    <Label fx:id="levelLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 12; -fx-font-weight: bold;
                  -fx-text-fill: #ffd700;"/>

    <!-- HP -->
    <Label fx:id="hpLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 11;
                  -fx-text-fill: #ff6666;"/>
    <ProgressBar fx:id="hpBar" maxWidth="Infinity" prefHeight="10"
                 style="-fx-accent: #e94560;"/>

    <!-- XP -->
    <Label fx:id="xpLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 11;
                  -fx-text-fill: #9b59b6;"/>
    <ProgressBar fx:id="xpBar" maxWidth="Infinity" prefHeight="8"
                 style="-fx-accent: #9b59b6;"/>

    <Separator/>

    <!-- Stats -->
    <Label text="-- STATS --" maxWidth="Infinity" alignment="CENTER"
           style="-fx-font-family: Monospace; -fx-font-size: 10;
                  -fx-text-fill: #606090;"/>
    <Label fx:id="atkLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 11;
                  -fx-text-fill: #ff8844;"/>
    <Label fx:id="defLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 11;
                  -fx-text-fill: #44aaff;"/>
    <Label fx:id="magLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 11;
                  -fx-text-fill: #cc66ff;"/>
    <Label fx:id="posLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 10;
                  -fx-text-fill: #606080;"/>
    <Label fx:id="floorLabel"
           style="-fx-font-family: Monospace; -fx-font-size: 11; -fx-font-weight: bold;
                  -fx-text-fill: #ffd700;"/>

    <Separator/>

    <!-- Inventario -->
    <Label text="-- ITEMS --" maxWidth="Infinity" alignment="CENTER"
           style="-fx-font-family: Monospace; -fx-font-size: 10;
                  -fx-text-fill: #606090;"/>
    <ListView fx:id="inventoryList" maxHeight="130"
              style="-fx-background-color: #080820;
                     -fx-control-inner-background: #080820;
                     -fx-font-family: Monospace; -fx-font-size: 10;"/>

</VBox>
