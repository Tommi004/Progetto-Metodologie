<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #000000;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg126224.view.GameViewController">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="15"
              style="-fx-background-color: #000000; -fx-padding: 8 15 8 15;
                     -fx-border-color: #1a1a3a; -fx-border-width: 0 0 1 0;">

            <Label text="⚔  LEVEL UP!"
                   style="-fx-font-family: Monospace; -fx-font-size: 16;
                          -fx-font-weight: bold; -fx-text-fill: #e94560;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="saveBtn" text="💾  Save" onAction="#handleSave"
                    style="-fx-background-color: #1a5c2a; -fx-text-fill: #c0c0e0;
                           -fx-font-family: Monospace; -fx-font-size: 12;
                           -fx-padding: 5 12; -fx-background-radius: 4; -fx-cursor: hand;"/>

            <Button fx:id="menuBtn" text="⬅  Menu" onAction="#handleMenu"
                    style="-fx-background-color: #333344; -fx-text-fill: #c0c0e0;
                           -fx-font-family: Monospace; -fx-font-size: 12;
                           -fx-padding: 5 12; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Hero status panel (left) — populated programmatically via fx:id -->
    <left>
        <fx:define>
            <!-- placeholder replaced at runtime by HeroStatusView.getRoot() -->
        </fx:define>
        <Pane fx:id="heroStatusPlaceholder" minWidth="190" maxWidth="190"/>
    </left>

    <!-- Center: room info + map placeholder + movement controls + message -->
    <center>
        <VBox alignment="CENTER" spacing="10"
              style="-fx-background-color: #000000; -fx-padding: 12;">

            <Label fx:id="roomInfoLabel" maxWidth="Infinity" alignment="CENTER"
                   style="-fx-font-family: Monospace; -fx-font-size: 12;
                          -fx-text-fill: #8080b0;"/>

            <Pane fx:id="mapPlaceholder" prefWidth="470" prefHeight="510" minWidth="470" minHeight="510"/>

            <Label fx:id="messageLabel" maxWidth="Infinity" alignment="CENTER"
                   style="-fx-font-family: Monospace; -fx-font-size: 12;
                          -fx-font-weight: bold; -fx-text-fill: #ffd700;"/>

        </VBox>
    </center>

</BorderPane>
